class Factorial inherits IO{
    factorial(n: Int): Int {
        {
            out_string("Test");
            if n = 0 then 1 else n * factorial(n - 1) fi
        }
    };
};


class Main inherits IO {
    ft : Factorial;
    answer : Int;
    main(): IO {
        {
            ft <- new Factorial;
            out_int(ft.factorial(5));
        }
    };
};